# Datenbankpasswort (frei wählbar)
POSTGRES_PASSWORD=sicherespasswort

# Geheimer Schlüssel für Flask-Sessions (lang und zufällig wählen)
SECRET_KEY=einlangesgeheimeszeichenfolge

# Basis-URL für QR-Codes – IP/Domain des Servers, KEIN localhost, KEIN trailing slash
QR_BASE_URL=http://192.168.1.100:5000
